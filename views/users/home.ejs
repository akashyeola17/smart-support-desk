<!DOCTYPE html>
<html>
<head>
  <title>Smart Support Desk</title>

  <style>
    body {
      font-family: Arial;
      margin: 0;
      background: #f5f6fa;
    }

    .navbar {
      background: #2c3e50;
      color: white;
      padding: 15px;
      font-size: 20px;
    }

    .container {
      padding: 30px;
    }

    .card-container {
      display: flex;
      gap: 20px;
      margin-top: 20px;
    }

    .card {
      background: white;
      padding: 20px;
      width: 200px;
      border-radius: 10px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      cursor: pointer;
      text-align: center;
    }

    .card:hover {
      background: #ecf0f1;
    }

    .tickets {
      margin-top: 30px;
    }

    .ticket {
      background: white;
      padding: 15px;
      margin-bottom: 10px;
      border-radius: 8px;
    }

  </style>
</head>

<body>

  <div class="navbar">
    Smart Support Desk
  </div>

  <div class="container">

    <h2>Welcome, <%= user.name %> 👋</h2>

    <div class="card-container">

      <div class="card" onclick="window.location='/tickets/create'">
        ➕<br><br>
        Raise Ticket
      </div>

      <div class="card" onclick="window.location='/tickets/list'">
        📄<br><br>
        My Tickets
      </div>

    </div>

    <div class="tickets">
      <h3>Recent Tickets</h3>

      <% tickets.forEach(t => { %>
        <div class="ticket">
          <strong><%= t.title %></strong><br>
          Status: <%= t.status %> | Priority: <%= t.priority %>
        </div>
      <% }) %>

    </div>

  </div>

</body>
</html>